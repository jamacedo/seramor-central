# URL do Web App do Apps Script (deploy: App da Web · acesso "Qualquer pessoa").
# Vazio => usa o mock fiel ao contrato (src/api/mock.ts), útil em dev.
VITE_API_URL=

# Painel /admin (Fase 6): 1 => usa o mock admin mesmo com VITE_API_URL setado
# (o backend admin ainda não existe). Remova/0 quando o Apps Script implementar
# adminDashboard/adminSearch/adminCheckin/adminCheckout/adminUpdatePhone.
VITE_ADMIN_MOCK=1

# Token compartilhado de auth do /admin. Deve casar com a Script Property
# `ADMIN_TOKEN` do Apps Script. Vazio => não envia (backend em modo dev).
VITE_ADMIN_TOKEN=
